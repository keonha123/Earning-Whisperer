# Copy this file to `.env` and fill in the runtime values you actually use.

# Required
GEMINI_API_KEY=your_gemini_api_key_here
REDIS_URL=redis://localhost:6379

# Gemini 3.x / LLM routing
# New primary/review settings
GEMINI_PRIMARY_MODEL=gemini-3-flash-preview
GEMINI_REVIEW_MODEL=gemini-3-pro-preview
GEMINI_PRIMARY_MAX_OUTPUT_TOKENS=384
GEMINI_STANDARD_MAX_OUTPUT_TOKENS=640
GEMINI_REVIEW_MAX_OUTPUT_TOKENS=960
GEMINI_PRIMARY_THINKING_LEVEL=minimal
GEMINI_STANDARD_THINKING_LEVEL=low
GEMINI_REVIEW_THINKING_LEVEL=medium

# Legacy compatibility keys (optional; new settings above take priority in code defaults)
# GEMINI_MODEL=gemini-3-pro-preview
# GEMINI_FAST_MODEL=gemini-3-flash-preview
# GEMINI_CONSENSUS_MODEL=gemini-3-pro-preview

GEMINI_MAX_TOKENS=2048
GEMINI_THINKING_LEVEL=minimal
GEMINI_MAX_RETRIES=3
GEMINI_BASE_RETRY_DELAY=1.5
GEMINI_CONSENSUS_SAMPLES=3
GEMINI_CONSENSUS_MIN_CONFIDENCE=0.78
GEMINI_CONSENSUS_DISAGREEMENT_THRESHOLD=0.35
LLM_ROUTER_MAX_CALLS_PER_CHUNK=2
LLM_ROUTER_NOVELTY_THRESHOLD=0.18
LLM_ROUTER_HIGH_SIGNAL_RAW_THRESHOLD=0.45
LLM_ROUTER_HIGH_PRIORITY=8
LLM_ROUTER_REVIEW_CONFIDENCE_THRESHOLD=0.68
PHASE1_PROVIDER=finbert
PHASE1_FINBERT_MODEL_NAME=ProsusAI/finbert
PHASE1_FINBERT_DEVICE=auto
PHASE1_FINBERT_MAX_LENGTH=256
PHASE1_MAX_CHARS=3000
PHASE1_CACHE_SIZE=1024
PHASE1_WARMUP_ON_STARTUP=true

# Optional external market data
ALPHAVANTAGE_API_KEY=demo

# Redis channels
REDIS_CHANNEL=trading-signals
REDIS_ENRICHED_CHANNEL=trading-signals-enriched
REDIS_BACKUP_QUEUE_SIZE=100
REDIS_RECONNECT_DELAY=2.0

# App
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Context and throughput
CONTEXT_HISTORY_SIZE=5
CONTEXT_SESSION_TTL_SECONDS=3600
ANALYSIS_MAX_PROMPT_TOKENS=12000
ANALYSIS_TARGET_CHUNK_TOKENS=2500
ANALYSIS_BATCH_CONCURRENCY=4
ANALYSIS_CONSENSUS_MAX_PARALLEL=2
RAG_HYBRID_ALPHA=0.70
RAG_DENSE_CANDIDATE_LIMIT=12
RAG_KEYWORD_CANDIDATE_LIMIT=24
RAG_BM25_K1=1.2
RAG_BM25_B=0.75
RAG_SCORE_DENSE_WEIGHT=0.55
RAG_SCORE_LEXICAL_WEIGHT=0.30
RAG_SCORE_BUSINESS_WEIGHT=0.15
VECTOR_STORE_BACKEND=qdrant
QDRANT_URL=http://localhost:6333
QDRANT_PATH=
# QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=external_evidence
QDRANT_TIMEOUT_SECONDS=5.0
QDRANT_PREFER_GRPC=false
EMBEDDING_PROVIDER=hash
EMBEDDING_MODEL=gemini-embedding-001
EMBEDDING_DIMENSION=256
EXTERNAL_CHUNK_SIZE_CHARS=3200
EXTERNAL_CHUNK_OVERLAP_CHARS=400

# Gate thresholds
COMPOSITE_THRESHOLD=0.55
CONFIDENCE_THRESHOLD=0.82
RAW_SCORE_THRESHOLD=0.45
MAX_EUPHEMISM_COUNT=2
MIN_VOLUME_RATIO=1.80
MAX_VIX=25.0

# Risk and research
KELLY_MAX_POSITION=0.25
EXECUTION_TARGET_WIN_RATE=0.50

# Composite weights (must sum to 1.0)
W_SENTIMENT=0.40
W_SUE=0.25
W_MOMENTUM=0.20
W_VOLUME=0.15
